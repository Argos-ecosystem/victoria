OMNI_URL=http://localhost:8001/analyze/custom
OMNI_API_MAX_CHARS=200
OMNI_DEFAULT_QUERY_HOURS=12
OMNI_DEFAULT_QUERY_MINUTES=60

# Required only for victoria_voice.py
OPENAI_API_KEY=

# Optional voice tuning
OPENAI_VOICE_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OMNI_ASR=openai
OMNI_PROCESSING_MESSAGE=Consultando el sistema central de inteligencia artificial.
OMNI_PROCESSING_VOICE=Paulina
OMNI_PROCESSING_RATE=175
OMNI_OPENAI_TIMEOUT_SECONDS=45
OMNI_REQUEST_TIMEOUT_SECONDS=60
OMNI_GOOGLE_ASR_TIMEOUT_SECONDS=8
OMNI_WAKEWORD_LISTEN_TIMEOUT_SECONDS=1
OMNI_WAKEWORD_PHRASE_TIME_LIMIT_SECONDS=3
OMNI_WAKEWORD_ERROR_SLEEP_SECONDS=0.5
OMNI_RECORDING_TIMEOUT_PADDING_SECONDS=3
OMNI_SOUND_TIMEOUT_SECONDS=3
OMNI_TTS_PLAYBACK_TIMEOUT_PADDING_SECONDS=10

# Optional ASR providers
GEMINI_API_KEY=
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
OMNI_GOOGLE_ASR_LANGUAGES=es-CL,es-ES,es-419
OMNI_LOCAL_ASR_MODEL=tiny
OMNI_LOCAL_ASR_TIMEOUT_SECONDS=60
